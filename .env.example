# ==============================================================================
# PazarB2B - UPUTSTVO ZA ENV VARIJABLE
# ==============================================================================
# OVO JE TEMPLEJT (PRIMER). NIKADA NE STAVLJAJ PRAVE ŠIFRE U OVAJ FAJL!
# Za lokalno pokretanje, kopiraj ovaj fajl u ".env" i unesi svoje ključeve.

# --- EXPO JAVNE VARIJABLE (Sigurno za frontend) ---
EXPO_PUBLIC_DOMAIN=http://localhost:5000
EXPO_PUBLIC_SUPABASE_URL=https://tvoj-projekat.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=tvoj_javni_anon_kljuc

# --- BACKEND TAJNE (STROGO POVERLJIVO - SAMO ZA SERVER) ---
DATABASE_URL=postgresql://korisnik:sifra@host:5432/pazarb2b
JWT_SECRET=tvoja_supertajna_sifra_za_enkripciju_tokena
SUPABASE_SERVICE_ROLE_KEY=tvoj_privatni_service_role_kljuc
