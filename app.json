{
  "expo": {
    "name": "Pazar B2B Višak",
    "slug": "pazarb2b",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "pazarb2b",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#EEF4F0"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.pazarb2b.visak"
    },
    "android": {
      "package": "com.pazarb2b.visak",
      "adaptiveIcon": {
        "backgroundColor": "#EEF4F0",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      }
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "2bf19d2d-02ba-469f-afed-63eaea2070e8"
      }
    },
    "owner": "blablaa"
  }
}
